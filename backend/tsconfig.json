{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true        // ✅ avoids type errors in node_modules
  },
  "ts-node": {
    "transpileOnly": true,      // ✅ skips type-check, no stale cache
    "files": true               // ✅ respects "files"/"include" entries
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}